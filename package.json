{
  "name": "cleanflow-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "client": "npm run dev --workspace=client",
    "agent": "npm run dev --workspace=agent",
    "business": "npm run dev --workspace=business",
    "admin": "npm run dev --workspace=admin",
    "hub": "npm run dev --workspace=@cleanflow/hub"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.0.0"
  }
}
