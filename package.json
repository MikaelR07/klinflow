{
  "name": "klinflow-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "client": "npm run dev --workspace=client",
    "agent": "npm run dev --workspace=agent",
    "business": "npm run dev --workspace=business",
    "admin": "npm run dev --workspace=admin",
    "hub": "npm run dev --workspace=@klinflow/hub"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "supabase": "^2.101.0",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "vite-plugin-compression": "^0.5.1",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "idb-keyval": "^6.2.4",
    "react-virtuoso": "^4.18.7",
    "workbox-background-sync": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
